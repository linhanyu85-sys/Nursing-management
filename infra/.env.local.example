APP_ENV=local
APP_NAME=ai-nursing-system
APP_VERSION=0.1.0

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_nursing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_nursing

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

NATS_HOST=localhost
NATS_PORT=4222
NATS_URL=nats://localhost:4222

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_CONSOLE_PORT=9001

PGADMIN_EMAIL=admin@local.test
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

BAILIAN_API_KEY=replace_with_your_bailian_api_key
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_MODEL_DEFAULT=qwen-max
BAILIAN_MODEL_COMPLEX=qwen-plus

FUNASR_BASE_URL=http://localhost:8101
COSYVOICE_BASE_URL=http://localhost:8102
MEDGEMMA_BASE_URL=http://localhost:8103

MOCK_MODE=true

JWT_SECRET=replace_this_secret
JWT_EXPIRE_MINUTES=1440

API_GATEWAY_PORT=8000
PATIENT_CONTEXT_SERVICE_PORT=8002
AGENT_ORCHESTRATOR_SERVICE_PORT=8003
HANDOVER_SERVICE_PORT=8004
RECOMMENDATION_SERVICE_PORT=8005
DOCUMENT_SERVICE_PORT=8006
AUDIT_SERVICE_PORT=8007
ASR_SERVICE_PORT=8008
TTS_SERVICE_PORT=8009
MULTIMODAL_MED_SERVICE_PORT=8010
COLLAB_SERVICE_PORT=8011
AUTH_SERVICE_PORT=8012

PATIENT_CONTEXT_SERVICE_URL=http://localhost:8002
AGENT_ORCHESTRATOR_SERVICE_URL=http://localhost:8003
HANDOVER_SERVICE_URL=http://localhost:8004
RECOMMENDATION_SERVICE_URL=http://localhost:8005
DOCUMENT_SERVICE_URL=http://localhost:8006
AUDIT_SERVICE_URL=http://localhost:8007
ASR_SERVICE_URL=http://localhost:8008
TTS_SERVICE_URL=http://localhost:8009
MULTIMODAL_MED_SERVICE_URL=http://localhost:8010
COLLAB_SERVICE_URL=http://localhost:8011
AUTH_SERVICE_URL=http://localhost:8012

EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_API_MOCK=true
