APP_ENV=prod
APP_NAME=ai-nursing-system
APP_VERSION=0.1.0

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ai_nursing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DSN=postgresql+asyncpg://postgres:change_me_postgres@127.0.0.1:5432/ai_nursing

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_URL=http://127.0.0.1:6333

NATS_HOST=127.0.0.1
NATS_PORT=4222
NATS_URL=nats://127.0.0.1:4222

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_CONSOLE_PORT=9001

PGADMIN_EMAIL=admin@linhanyu.com
PGADMIN_PASSWORD=change_me_pgadmin
PGADMIN_PORT=5050

BAILIAN_API_KEY=replace_with_your_bailian_api_key
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_MODEL_DEFAULT=qwen3-coder-plus
BAILIAN_MODEL_COMPLEX=qwen3-coder-plus

LOCAL_ONLY_MODE=false
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://127.0.0.1:9100/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL_PRIMARY=minicpm3-4b-q4_k_m
