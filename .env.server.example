LOCAL_LLM_MODEL_PLANNER=qwen3-8b
LOCAL_LLM_MODEL_REASONING=deepseek-r1-distill-qwen-7b
LOCAL_LLM_MODEL_CUSTOM=
LOCAL_LLM_MODEL_MULTIMODAL=medgemma-4b-it
LOCAL_LLM_TIMEOUT_SEC=18
AGENT_PLANNER_LLM_ENABLED=true
AGENT_PLANNER_TIMEOUT_SEC=18
AGENT_PLANNER_MAX_STEPS=8
AGENT_MEMORY_RECALL_LIMIT=6
AGENT_QUEUE_WORKER_ENABLED=true
AGENT_QUEUE_POLL_INTERVAL_SEC=1.0

